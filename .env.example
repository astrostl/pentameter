# Pentameter Configuration
# Copy this file to .env and update the values for your environment

# IntelliCenter IP address (optional - auto-discovers via mDNS if not provided)
# PENTAMETER_IC_IP=192.168.1.100

# IntelliCenter WebSocket port (optional, default: 6680)
# PENTAMETER_IC_PORT=6680

# HTTP server port for metrics endpoint (optional, default: 8080)
# PENTAMETER_HTTP_PORT=8080

# Polling interval in seconds (optional, default: 60, minimum: 5)
# PENTAMETER_INTERVAL=60

# Enable listen mode for real-time event monitoring (optional, default: false)
# PENTAMETER_LISTEN=false

# TRMNL e-ink display push (optional). Set to your TRMNL private-plugin webhook
# URL to push pool data to TRMNL alongside the active mode. See TRMNL.md.
# Treat this URL as a secret. Ignored in listen mode.
# PENTAMETER_TRMNL_WEBHOOK=https://trmnl.com/api/custom_plugins/your-uuid-here

# Seconds between TRMNL pushes (optional, default: 300, minimum: 60)
# PENTAMETER_TRMNL_INTERVAL=300